# Copia este archivo a .env para personalizar el entorno local.
# Valores solo para desarrollo; usa credenciales fuertes en producción.
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=encuestas
MYSQL_USER=encuestas
MYSQL_PASSWORD=encuestas
# Cambia los puertos si otro proyecto ya los usa en tu máquina.
MYSQL_PORT=3306
WEB_PORT=8080
# Secreto fijo para firmar los tokens de confirmación y restablecimiento (opcional):
# si queda vacío, la app genera y rota sus claves en el volumen web-keys.
APP_TOKEN_SECRET=
